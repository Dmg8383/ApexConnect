{
  "expo": {
    "name": "ApexConnect",
    "slug": "apexconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apexconnect.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ApexConnect uses your photo library to share images in chats.",
        "NSCameraUsageDescription": "ApexConnect uses your camera for video calls and sharing photos.",
        "NSMicrophoneUsageDescription": "ApexConnect uses your microphone for voice and video calls.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow ApexConnect to access your camera for video calls.",
          "microphonePermission": "Allow ApexConnect to access your microphone for voice and video calls."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.21",
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.apexconnect.app",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "247e930d-149f-4660-b6cd-23451786cb5c"
      }
    }
  }
}
